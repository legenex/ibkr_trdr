# Copy this file to .env and fill in real values. .env is gitignored and must
# never be committed. Every key below is read and validated by config.py.

# ----------------------------------------------------------------------------
# IBKR connection
# ----------------------------------------------------------------------------
IBKR_HOST=127.0.0.1
# Ports: paper TWS 7497, live TWS 7496, IB Gateway paper 4002, IB Gateway live 4001.
IBKR_PAPER_PORT=7497
IBKR_LIVE_PORT=7496
IBKR_GATEWAY_PAPER_PORT=4002
IBKR_GATEWAY_LIVE_PORT=4001
IBKR_CLIENT_ID=1
# Set true only if connecting through IB Gateway instead of TWS.
USE_IB_GATEWAY=false

# ----------------------------------------------------------------------------
# Live trading safety
# ----------------------------------------------------------------------------
# Paper is the default. Live trading requires BOTH this flag set to true AND a
# typed runtime confirmation string that must equal LIVE_CONFIRMATION_PHRASE.
# With either missing, the broker connects to the paper port only.
LIVE_TRADING=false
LIVE_CONFIRMATION_PHRASE=I UNDERSTAND THIS IS REAL MONEY

# ----------------------------------------------------------------------------
# Secrets (optional until later build stages)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Data provider keys. yfinance needs none. Polygon is an optional backup source.
POLYGON_API_KEY=

# ----------------------------------------------------------------------------
# Risk parameters (all are hard limits enforced by the guardrails module).
# Percent values are percent of account equity unless noted.
# ----------------------------------------------------------------------------
# Halt new entries if equity drops this percent from the day's start.
MAX_DAILY_DRAWDOWN_PCT=3
# Halt new entries if equity drops this percent from the week's start.
MAX_WEEKLY_DRAWDOWN_PCT=6
# Capital risked per trade (entry to stop). Must be between 0 and 5 percent.
RISK_PER_TRADE_PCT=0.5
# Maximum total gross exposure (sum of absolute position values).
MAX_GROSS_EXPOSURE_PCT=100
# Maximum weight of any single name.
MAX_SINGLE_NAME_WEIGHT_PCT=10
# Maximum combined exposure across a correlated cluster.
MAX_CORRELATED_CLUSTER_EXPOSURE_PCT=25
# Minimum liquidity, as average daily volume in shares, to allow a symbol.
MIN_LIQUIDITY_ADV=1000000
# Maximum order size as a percent of the symbol's average daily volume.
MAX_ADV_PARTICIPATION_PCT=5
# Maximum gross-exposure-to-equity ratio. 1.0 means no leverage.
MAX_LEVERAGE=1.0
# Absolute return correlation at or above which two names share a cluster.
CORRELATION_CLUSTER_THRESHOLD=0.7
# Minimum overlapping return observations before a correlation is trusted.
CORRELATION_MIN_PERIODS=20

# ----------------------------------------------------------------------------
# Operations
# ----------------------------------------------------------------------------
# Sentinel file. If it exists, the main loop halts all new order submission.
KILL_SWITCH_FILE=journal/KILL_SWITCH
JOURNAL_DIR=journal
DATA_CACHE_DIR=journal/cache
LOG_LEVEL=INFO
# Deterministic seed for reproducible model fits and sampling.
RANDOM_SEED=42

# ----------------------------------------------------------------------------
# Orchestrator and scheduler (main.py)
# ----------------------------------------------------------------------------
WATCHLIST=SPY,AAPL,MSFT
REGIME_PROXY_SYMBOL=SPY
TRADING_INTERVAL_SECONDS=60
# Slower discovery cadence. Off by default; proposals never auto-approve.
DISCOVERY_ENABLED=false
DISCOVERY_INTERVAL_MINUTES=1440
DISCOVERY_THEME=scheduled watchlist scan
# Reward-to-risk multiple for orchestrator-built bracket targets.
BRACKET_REWARD_RISK=2.0

# ----------------------------------------------------------------------------
# Self-learning loop (runs outside the trading cycle; never places orders)
# ----------------------------------------------------------------------------
# Cadence: off | daily | after_trades
LEARNING_CADENCE=off
LEARNING_AFTER_N_TRADES=5
LEARNING_INTERVAL_MINUTES=1440
# Per-run LLM budget. Exhausted -> skip the LLM steps that cycle and log it.
LEARNING_TOKEN_BUDGET=200000
LEARNING_COST_BUDGET_USD=5.0
